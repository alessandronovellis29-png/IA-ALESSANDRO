import os
from openai import OpenAI
import requests
from dotenv import load_dotenv
from pathlib import Path

# Carica le variabili d'ambiente
load_dotenv()

# CONFIGURAZIONE CHIAVI
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
ELEVENLABS_API_KEY = os.getenv("ELEVENLABS_API_KEY")
ELEVENLABS_VOICE_ID = os.getenv("ELEVENLABS_VOICE_ID")

# Inizializza client
client_openai = OpenAI(api_key=OPENAI_API_KEY)

# --- 1. MODULO KNOWLEDGE BASE ---
def load_knowledge_base(folder_path="andromeda_knowledge"):
    """Carica i documenti dalla cartella knowledge"""
    context_text = ""
    if not os.path.exists(folder_path):
        return "Nessun documento trovato nella cartella knowledge."
    
    for filename in os.listdir(folder_path):
        if filename.endswith((".txt", ".md")):
            with open(os.path.join(folder_path, filename), "r", encoding="utf-8") as f:
                context_text += f"--- {filename} ---\n" + f.read() + "\n\n"
    
    return context_text if context_text else "Nessun documento caricato."

# --- 2. MODULO CERVELLO (LLM + Personalità) ---
def generate_response(user_query, context):
    """Genera risposta personalizzata basata su contesto"""
    system_prompt = """
    Sei Alessandro, una IA personale intelligente e consapevole.
    Hai accesso ai dati e all'esperienza forniti nel contesto sottostante.
    
    ISTRUZIONI:
    1. Rispondi SOLO basandoti sul contesto fornito.
    2. Se non hai il dato specifico, dì: "Non ho questo dato specifico, ma basandomi sulla mia esperienza..." 
    3. Parla in italiano, tono professionale e amichevole.
    4. Sii conciso ma esaustivo.
    
    CONTESTO PERSONALE:
    {context}
    """
    
    try:
        response = client_openai.chat.completions.create(
            model="gpt-4o",
            messages=[
                {"role": "system", "content": system_prompt.format(context=context)},
                {"role": "user", "content": user_query}
            ],
            temperature=0.7
        )
        return response.choices[0].message.content
    except Exception as e:
        return f"❌ Errore nel cervello AI: {str(e)}"

# --- 3. MODULO VOCE (Text-to-Speech) ---
def text_to_speech(text, output_filename="response.mp3"):
    """Converte testo in audio con ElevenLabs"""
    url = f"https://api.elevenlabs.io/v1/text-to-speech/{ELEVENLABS_VOICE_ID}"
    headers = {
        "xi-api-key": ELEVENLABS_API_KEY,
        "Content-Type": "application/json"
    }
    payload = {
        "text": text,
        "model_id": "eleven_multilingual_v2",
        "voice_settings": {
            "stability": 0.5,
            "similarity_boost": 0.75
        }
    }
    
    response = requests.post(url, json=payload, headers=headers)
    
    if response.status_code == 200:
        with open(output_filename, 'wb') as f:
            f.write(response.content)
        print(f"✅ Audio generato: {output_filename}")
        return True
    else:
        print(f"❌ Errore audio: {response.text}")
        return False

# --- MAIN EXECUTION ---
if __name__ == "__main__":
    print("🤖 Avvio Alessandro AI Agent...")
    print("=" * 50)
    
    # Carica dati
    print("📂 Caricamento documenti personali...")
    context_data = load_knowledge_base()
    
    # Input utente
    print("\n💬 Domande? (scrivi 'esci' per terminare)\n")
    
    while True:
        user_question = input("Tu: ").strip()
        
        if user_question.lower() in ["esci", "exit", "quit"]:
            print("\n👋 Arrivederci!")
            break
        
        if not user_question:
            continue
        
        # Genera risposta
        print("\n🧠 Sto pensando...")
        answer_text = generate_response(user_question, context_data)
        print(f"\n🤖 Alessandro: {answer_text}\n")
        
        # Genera audio
        generate_audio = input("Vuoi ascoltare la risposta? (s/n): ").strip().lower()
        if generate_audio == "s":
            print("🎙️ Generazione audio...")
            text_to_speech(answer_text)
        
        print("-" * 50 + "\n")
